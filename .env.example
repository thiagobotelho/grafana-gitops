# Namespace da instância Grafana no CRC.
GRAFANA_NAMESPACE=grafana
GRAFANA_OAUTH_SECRET=grafana-oauth

# Keycloak que provê o client OIDC do Grafana.
KEYCLOAK_NAMESPACE=keycloak-dev
KEYCLOAK_ADMIN_SECRET=keycloak-dev-initial-admin
KEYCLOAK_ROUTE_NAME=keycloak
# Opcional. Se vazio, o script descobre a URL pela Route do Keycloak.
KEYCLOAK_BASE_URL=
KEYCLOAK_REALM=observability
KEYCLOAK_GRAFANA_CLIENT_ID=grafana

# Secret consumido pelo datasource Zabbix.
# Ele é criado pelo script scripts/bootstrap-zabbix.sh no repo zabbix-gitops.
ZABBIX_DATASOURCE_SECRET=zabbix-datasource
